<html>
<head>
<title>Minecraft Server Launcher</title>
<HTA:APPLICATION
  APPLICATIONNAME="Minecraft Server Launcher"
  WINDOWSTATE="normal"
  INNERBORDER="no"
  SCROLL="no"
  SINGLEINSTANCE="yes"
  MINIMIZEBUTTON="yes"
  MAXIMIZEBUTTON="yes"
/>
<style>
  *{box-sizing:border-box;margin:0;padding:0;}
  body{background:#1e1e1e;font-family:Consolas,monospace;color:#ccc;overflow:hidden;}
  .titlebar{background:#1e1e1e;padding:10px 16px;display:flex;align-items:center;gap:10px;border-bottom:1px solid #2a2a2a;}
  .green-sq{width:14px;height:14px;background:#3B6D11;border-radius:2px;}
  .titlebar-text{color:#97C459;font-size:13px;font-weight:bold;letter-spacing:2px;}
  .cards{padding:12px 16px 0;display:flex;flex-direction:column;}
  .card{background:#252525;border:1px solid #2e2e2e;padding:12px 16px;}
  .card+.card{border-top:none;}
  .card:first-child{border-radius:6px 6px 0 0;}
  .card:last-child{border-radius:0 0 6px 6px;}
  .lbl{font-size:10px;color:#666;letter-spacing:1px;margin-bottom:5px;}
  .val{font-size:14px;font-weight:bold;}
  .green{color:#97C459;} .yellow{color:#EF9F27;} .blue{color:#378ADD;} .gray{color:#666;}
  .btn-row{padding:12px 16px;display:flex;gap:0;}
  button{flex:1;padding:10px 0;border:1px solid #333;font-family:Consolas,monospace;font-size:12px;font-weight:bold;cursor:pointer;background:#1e1e1e;color:#ccc;}
  button:first-child{border-radius:5px 0 0 5px;}
  button:last-child{border-radius:0 5px 5px 0;}
  button+button{border-left:none;}
  #btnStart{background:#3B6D11;color:#C0DD97;border-color:#3B6D11;}
  #btnStop{color:#E24B4A;}
  #btnSync{color:#378ADD;}
  #btnHandoff{color:#EF9F27;}
  #console{margin:0 16px;background:#0a0a0a;border:1px solid #2a2a2a;border-radius:6px;height:220px;overflow-y:auto;padding:10px 14px;font-size:12px;line-height:1.8;}
  .footer{padding:10px 16px;display:flex;justify-content:space-between;align-items:center;}
  .footer-info{font-size:10px;color:#555;}
  .pill{font-size:11px;padding:3px 12px;border-radius:4px;font-weight:bold;}
  .pill-off{background:#3a1212;color:#E24B4A;border:1px solid #5a1a1a;}
  .pill-on{background:#1a2e12;color:#97C459;border:1px solid #3B6D11;}
</style>
</head>
<body>

<div class="titlebar">
  <div class="green-sq"></div>
  <span class="titlebar-text">MINECRAFT SERVER LAUNCHER</span>
</div>

<div class="cards">
  <div class="card"><div class="lbl">STATUS</div><div class="val gray" id="statusVal">&#9644; Offline</div></div>
  <div class="card"><div class="lbl">UPTIME</div><div class="val yellow" id="uptimeVal">--:--:--</div></div>
  <div class="card"><div class="lbl">RAM</div><div class="val blue">2 GB allocated</div></div>
  <div class="card"><div class="lbl">RESTARTS</div><div class="val gray" id="restartVal">0</div></div>
</div>

<div class="btn-row">
  <button id="btnStart"   onclick="StartServer()">&#9654; Start server</button>
  <button id="btnStop"    onclick="StopServer()">&#9632; Stop server</button>
  <button id="btnSync"    onclick="GitSync()">&#8593; Git sync</button>
  <button id="btnHandoff" onclick="Handoff()">&#8644; Hand off</button>
</div>

<div id="console"></div>

<div class="footer">
  <span class="footer-info">Java: jdk-21.0.10.7 &nbsp;|&nbsp; G1GC + Aikar &nbsp;|&nbsp; Paper</span>
  <span class="pill pill-off" id="pill">&#9644; Offline</span>
</div>

<script language="VBScript">
  Dim oShell, running, restarts, startTime, uptimeTimer

  running = False
  restarts = 0

  Sub Window_onLoad()
    Set oShell = CreateObject("WScript.Shell")
    AddLog "[READY] Launcher started. Click Start Server to begin.", "#888888"
  End Sub

  Sub AddLog(msg, col)
    Dim c
    c = document.getElementById("console")
    c.innerHTML = c.innerHTML & "<div style='color:" & col & "'>" & msg & "</div>"
    c.scrollTop = c.scrollHeight
  End Sub

  Sub SetOnline(isOn)
    If isOn Then
      document.getElementById("statusVal").innerHTML = "<span style='color:#97C459'>&#9644; Online</span>"
      document.getElementById("pill").className = "pill pill-on"
      document.getElementById("pill").innerText = "● Online"
    Else
      document.getElementById("statusVal").innerHTML = "<span style='color:#666'>&#9644; Offline</span>"
      document.getElementById("pill").className = "pill pill-off"
      document.getElementById("pill").innerText = "● Offline"
    End If
  End Sub

  Function GetPath()
    Dim p
    p = document.location.pathname
    p = Left(p, InStrRev(p, "/") - 1)
    p = Replace(p, "/", "\")
    If Left(p, 1) = "\" Then p = Mid(p, 2)
    GetPath = p
  End Function

  Sub StartServer()
    If running Then Exit Sub
    running = True
    restarts = restarts + 1
    document.getElementById("restartVal").innerText = restarts
    SetOnline True
    AddLog "[GIT]   Pulling latest world from GitHub...", "#378ADD"
    oShell.Run "cmd /c cd /d """ & GetPath() & """ && git pull origin main", 0, True
    AddLog "[GIT]   Pull complete.", "#97C459"
    AddLog "[START] Starting server... (attempt " & restarts & ")", "#97C459"
    startTime = Now()
    oShell.Run "cmd /c cd /d """ & GetPath() & """ && """ & "C:\Program Files\Eclipse Adoptium\jdk-21.0.10.7-hotspot\bin\java.exe" & """ -Xms2G -Xmx2G -XX:+UseG1GC -XX:+ParallelRefProcEnabled -XX:MaxGCPauseMillis=200 -XX:+UnlockExperimentalVMOptions -XX:+DisableExplicitGC -XX:G1NewSizePercent=30 -XX:G1MaxNewSizePercent=40 -XX:G1HeapRegionSize=8M -XX:G1ReservePercent=20 -XX:G1HeapWastePercent=5 -XX:G1MixedGCCountTarget=4 -XX:InitiatingHeapOccupancyPercent=15 -XX:G1MixedGCLiveThresholdPercent=90 -XX:G1RSetUpdatingPauseTimePercent=5 -XX:SurvivorRatio=32 -XX:+PerfDisableSharedMem -XX:MaxTenuringThreshold=1 -jar server.jar nogui", 1, False
    uptimeTimer = window.setInterval("TickUptime()", 1000)
    AddLog "[INFO]  Server process launched.", "#666666"
  End Sub

  Sub StopServer()
    If Not running Then Exit Sub
    running = False
    window.clearInterval(uptimeTimer)
    SetOnline False
    document.getElementById("uptimeVal").innerText = "--:--:--"
    oShell.Run "taskkill /F /IM java.exe", 0, True
    AddLog "[STOP]  Server stopped.", "#EF9F27"
    AddLog "[GIT]   Pushing world to GitHub...", "#378ADD"
    oShell.Run "cmd /c cd /d """ & GetPath() & """ && git add world/ world_nether/ world_the_end/ && git commit -m ""World update"" && git push origin main", 0, True
    AddLog "[GIT]   Push complete.", "#97C459"
  End Sub

  Sub GitSync()
    AddLog "[GIT]   Syncing world to GitHub...", "#378ADD"
    oShell.Run "cmd /c cd /d """ & GetPath() & """ && git add world/ world_nether/ world_the_end/ && git commit -m ""Manual sync"" && git push origin main", 0, True
    AddLog "[GIT]   Sync complete.", "#97C459"
  End Sub

  Sub Handoff()
    Call StopServer()
    AddLog "[HAND]  World pushed! Tell your friend to start his launcher.", "#EF9F27"
    MsgBox "World synced to GitHub!" & Chr(13) & "Tell your friend to start his launcher now.", 64, "Hand Off"
  End Sub

  Sub TickUptime()
    Dim diff, h, m, s
    diff = DateDiff("s", startTime, Now())
    h = Right("0" & (diff \ 3600), 2)
    m = Right("0" & ((diff Mod 3600) \ 60), 2)
    s = Right("0" & (diff Mod 60), 2)
    document.getElementById("uptimeVal").innerText = h & ":" & m & ":" & s
  End Sub
</script>
</body>
</html>